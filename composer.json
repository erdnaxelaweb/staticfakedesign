{
    "name":  "erdnaxelaweb/staticfakedesign",
    "type": "symfony-bundle",
    "description": "Generate realistic-looking static HTML/CSS/JS based on fake data",
    "keywords": [
      "sympfony",
      "twig",
      "faker",
      "front-end-development",
      "ui-prototyping"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "fakerphp/faker": "^1.23",
        "symfony/translation": "^7.0",
        "babdev/pagerfanta-bundle": "^4.6",
        "knplabs/knp-menu-bundle": "^3.0",
        "symfony/options-resolver": "^7.0",
        "doctrine/collections": "^2.0",
        "smknstd/fakerphp-picsum-images": "^1.0",
        "symfony/form": "^7.0",
        "twig/intl-extra": "^3.0",
        "jms/translation-bundle": "^2.0",
        "symfony/yaml": "^7.0",
        "symfony/expression-language": "^7.0",
        "symfony/twig-bundle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "symplify/easy-coding-standard": "^13.0",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-symfony": "^2.0",
        "rector/rector": "^2.3"
    },
    "suggest": {
        "ext-dom": "*"
    },
    "authors": [
        {
            "name": "Florian ALEXANDRE"
        }
    ],
    "scripts": {
        "check-cs": [
            "ecs"
        ],
        "fix-cs": [
            "ecs --fix"
        ],
        "tests": [
            "vendor/bin/phpstan",
            "vendor/bin/phpunit tests"
        ]
    },
    "autoload": {
        "psr-4": {
            "ErdnaxelaWeb\\StaticFakeDesignBundle\\": "bundle",
            "ErdnaxelaWeb\\StaticFakeDesign\\": "lib",
            "ErdnaxelaWeb\\StaticFakeDesign\\Tests\\": "tests"
        }
    }
}
